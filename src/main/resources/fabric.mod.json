{
	"schemaVersion": 1,
	"id": "jujutsumod",
	"version": "${version}",
	"name": "Jujutsu Minecraft",
	"description": "A Fabric jujutsu combat mod focused on polished character kits and readable cinematic VFX.",
	"authors": [
		"Jujutsu Minecraft team"
	],
	"license": "CC0-1.0",
	"icon": "assets/jujutsumod/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"jujutsu.mod.JujutsuMod"
		],
		"client": [
			"jujutsu.mod.client.JujutsuModClient"
		]
	},
	"mixins": [
		{
			"config": "jujutsumod.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~1.21.8",
		"java": ">=21",
		"fabric-api": "*",
		"geckolib": ">=5.2.2"
	}
}
